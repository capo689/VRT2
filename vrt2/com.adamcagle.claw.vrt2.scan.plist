<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.adamcagle.claw.vrt2.scan</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/node</string>
        <string>/Users/adamcagle/CLAW/VRT2/jobs/browser_runner_vrt2.js</string>
    </array>

    <key>WorkingDirectory</key>
